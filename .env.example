# ==========================================
# Odoo Development Environment Configuration
# ==========================================

# --- Project Settings ---
PROJECT_NAME=my-odoo-project
# Docker Compose uses this to name containers (<project>-<service>-<n>)
COMPOSE_PROJECT_NAME=my-odoo-project

# --- Odoo Settings ---
ODOO_VERSION=19.0
ODOO_IMAGE=odoo:19
# Port to access Odoo from host (e.g. localhost:8069)
WEB_PORT=8069
# Admin password for database management
ADMIN_PASSWORD=admin
# Language to install (e.g. es_ES, en_US, fr_FR)
LOAD_LANGUAGE=en_US
# Skip demo data for these modules ("all" to skip all demo data)
WITHOUT_DEMO=all
# DB Filter (regex pattern to match database name)
DB_FILTER=^odoo_db$

# --- Database Settings ---
DB_IMAGE=pgvector/pgvector:pg16
DB_PORT=5432
DB_NAME=odoo_db
DB_USER=odoo
DB_PASSWORD=odoo
DB_HOST=db

# --- Extra Settings ---
# Port for pgweb database GUI
PGWEB_PORT=8081
# Enable advanced debugging with debugpy (True/False)
DEBUGPY=False
# Port for debugpy (only used when DEBUGPY=True)
DEBUGPY_PORT=5678
# Comma separated list of modules to install at startup (optional)
# INIT_MODULES=base,web
