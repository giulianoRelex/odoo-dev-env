[options]
addons_path = /mnt/extra-addons,/mnt/extra-addons/reswoy,/mnt/extra-addons/reswoy/maximia-hr/custom_addons,/mnt/extra-addons/ingadhoc/odoo-argentina,/mnt/extra-addons/ingadhoc/odoo-argentina-ee,/mnt/extra-addons/ingadhoc/account-invoicing,/mnt/extra-addons/ingadhoc/multi-company,/mnt/extra-addons/ingadhoc/aeroo_reports,/mnt/extra-addons/ingadhoc/stock,/mnt/extra-addons/ingadhoc/product,/mnt/extra-addons/ingadhoc/purchase,/mnt/extra-addons/ingadhoc/account-payment,/mnt/extra-addons/ingadhoc/argentina-sale,/mnt/extra-addons/ingadhoc/miscellaneous,/mnt/extra-addons/ingadhoc/account-financial-tools,/mnt/extra-addons/ingadhoc/sale,/mnt/extra-addons/OCA/sale-workflow,/mnt/extra-addons/OCA/stock-logistics-workflow,/mnt/enterprise-addons
data_dir = /var/lib/odoo
admin_passwd = {{ ADMIN_PASSWORD | default('admin') }}
csv_internal_sep = ,
db_host = {{ DB_HOST | default('db') }}
db_port = 5432
db_user = {{ DB_USER | default('odoo') }}
db_password = {{ DB_PASSWORD | default('odoo') }}
db_name = {{ DB_NAME | default('odoo_db') }}
log_level = info
; logfile disabled — output goes to stderr (captured by Docker) and tee'd to /var/log/odoo/odoo.log via entrypoint
http_interface = 0.0.0.0
