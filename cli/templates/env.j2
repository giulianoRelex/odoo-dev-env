# ==========================================
# Odoo Development Environment Configuration
# ==========================================
# Generated by: odoodev init

# --- Project Settings ---
PROJECT_NAME={{ PROJECT_NAME | default('my-odoo-project') }}
# Docker Compose uses this to name containers (<project>-<service>-<n>)
COMPOSE_PROJECT_NAME={{ PROJECT_NAME | default('my-odoo-project') }}

# --- Odoo Settings ---
ODOO_VERSION={{ ODOO_VERSION | default('19.0') }}
ODOO_IMAGE=odoo:{{ ODOO_VERSION | default('19.0') | replace('.0', '') }}
# Port to access Odoo from host (e.g. localhost:8069)
WEB_PORT={{ WEB_PORT | default('8069') }}
# Admin password for database management
ADMIN_PASSWORD={{ ADMIN_PASSWORD | default('admin') }}
# Language to install (e.g. es_ES, en_US, fr_FR)
LOAD_LANGUAGE={{ LOAD_LANGUAGE | default('en_US') }}
# Skip demo data for these modules ("all" to skip all demo data)
WITHOUT_DEMO={{ WITHOUT_DEMO | default('all') }}
# DB Filter (regex pattern to match database name)
DB_FILTER=^{{ DB_NAME | default('odoo_db') }}$

# --- Database Settings ---
DB_IMAGE=pgvector/pgvector:pg{{ DB_IMAGE_TAG | default('16') }}
DB_PORT={{ DB_PORT | default('5432') }}
DB_NAME={{ DB_NAME | default('odoo_db') }}
DB_USER={{ DB_USER | default('odoo') }}
DB_PASSWORD={{ DB_PASSWORD | default('odoo') }}
DB_HOST=db

# --- Extra Settings ---
# Port for pgweb database GUI
PGWEB_PORT={{ PGWEB_PORT | default('8081') }}
# Enable advanced debugging with debugpy (True/False)
DEBUGPY={{ DEBUGPY | default('False') }}
# Port for debugpy (only used when DEBUGPY=True)
DEBUGPY_PORT={{ DEBUGPY_PORT | default('5678') }}
# Comma separated list of modules to install at startup (leave empty for none)
INIT_MODULES={{ INIT_MODULES | default('') }}
